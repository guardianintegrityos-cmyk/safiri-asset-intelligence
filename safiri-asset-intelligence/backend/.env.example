# ============================================
# SAFIRI ASSET INTELLIGENCE - ENVIRONMENT CONFIGURATION
# Guardian Academy - Financial-Grade Security
# ============================================

# ============================================
# CORE SECURITY SETTINGS
# ============================================

# JWT Secret (change this to a strong random string in production!)
# Generate with: python -m secrets.token_urlsafe(32)
SECRET_KEY=your-secret-key-change-in-production

# Encryption key for sensitive data
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-change-in-production

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/safiri_db
DATABASE_SSL_MODE=prefer

# Neo4j (for identity graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ============================================
# FRONTEND & DEPLOYMENT
# ============================================

FRONTEND_URL=https://safiri.guardian-academy.org
LOG_LEVEL=INFO

# ============================================
# TWO-FACTOR AUTHENTICATION (OTP)
# ============================================

# Twilio SMS service for OTP delivery
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# CLOUDFLARE WAF (Optional but recommended)
# ============================================

CLOUDFLARE_API_KEY=your-cloudflare-api-key
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# ============================================
# EMAIL SERVICE (for verification)
# ============================================

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@safiri.org

# ============================================
# ENVIRONMENT
# ============================================

ENVIRONMENT=development
# Options: development, staging, production

# ============================================
# SECURITY HEADERS
# ============================================

ENFORCE_HTTPS=true
HSTS_MAX_AGE=31536000
